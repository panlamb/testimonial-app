{
  "name": "testimonial-app",
  "version": "1.0.0",
  "description": "Testimonial & Social Proof Collector",
  "main": "server/index.js",
  "scripts": {
    "start": "node --experimental-sqlite --no-warnings=ExperimentalWarning server/index.js",
    "dev:server": "nodemon --exec 'node --experimental-sqlite --no-warnings=ExperimentalWarning' server/index.js",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=22"
  }
}
